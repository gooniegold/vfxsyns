# Copy to .env.local and fill in values (never commit .env.local)

# Shopify Storefront API (public token is safe for browser — still don't expose in public repos unnecessarily)
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here

# Stripe publishable key (optional — Shopify checkout already uses Stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
NEXT_PUBLIC_CHECKOUT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Map site product handles to Stripe Price IDs (from Dashboard → Product → Pricing → price_…)
STRIPE_PRICE_MAP={"quickdraft":"price_123","vfx-pack-01":"price_456"}
# Map handles → hosted download URLs. Stripe does NOT host your files; use R2/S3/Drive/Vercel Blob, etc.
STRIPE_DOWNLOAD_URL_MAP={"quickdraft":"https://yourdomain.com/downloads/quickdraft.zip","vfx-pack-01":"https://yourdomain.com/downloads/vfx-pack-01.zip"}
# Fallback when a product has no download_url in Stripe metadata and no handle match above
STRIPE_DEFAULT_DOWNLOAD_URL=https://yourdomain.com/downloads/quickdraft.zip
LICENSE_MAX_ACTIVATIONS=1
# Maps Stripe / shop handles → license worker `product` id (must match your Worker). Defaults to quickdraft if unset.
LICENSE_PRODUCT_MAP={"quickdraft-free":"quickdraft_free","quickdraft-pro":"quickdraft_pro","quickdraft":"quickdraft"}

# Optional per-product overrides in Stripe Dashboard → Product → Metadata:
#   download_url       = https://... (direct or signed link to your zip/installer)
#   product_handle     = same key as in STRIPE_PRICE_MAP / your site (if checkout has no session metadata)
#   max_activations    = number (overrides LICENSE_MAX_ACTIVATIONS for that product)

# Self-hosted only: serve files from a folder on the same machine that runs Next.js (your PC or VPS).
# Vercel cannot read your home PC. Set NEXT_PUBLIC_APP_URL to your public URL (HTTPS).
# DOWNLOAD_FILE_MAP values must be plain filenames only (no subpaths), e.g. "QuickDraft.zip"
DOWNLOAD_FILES_ROOT=C:\Users\You\Builds
DOWNLOAD_FILE_MAP={"quickdraft":"QuickDraft-Setup.zip","quickdraft-pro":"QuickDraft-Pro.zip"}
DOWNLOAD_SIGNING_SECRET=use_a_long_random_string_here
DOWNLOAD_LINK_TTL_SEC=604800
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Thank-you page: Stripe success_url should be https://yourdomain.com/thank-you?session_id={CHECKOUT_SESSION_ID}
# Optional opaque ref for Sellhub or other tools: …&ref=ORDER_REF (display-only; add server lookup later if needed)
# Optional link shown on thank-you when using Sellhub customer portal:
# NEXT_PUBLIC_SELLHUB_CUSTOMER_PORTAL_URL=https://sellhub.cx/your-store/customer

# QuickDraft licensing bridge (server-side only)
LICENSE_API_BASE_URL=https://your-quickdraft-license-worker.workers.dev
LICENSE_ADMIN_TOKEN=replace_with_worker_admin_token
LICENSE_ISSUE_SECRET=replace_with_long_random_secret
LICENSE_WEBHOOK_SECRET=replace_with_long_random_webhook_secret

# Admin panel login (/admin/login)
ADMIN_PANEL_USERNAME=owner
ADMIN_PANEL_PASSWORD=vfxsyn20
ADMIN_PANEL_SESSION_SECRET=vfxsyn20-session-secret-change-me

# Delivery email (Resend)
RESEND_API_KEY=re_xxxxxxxxx
LICENSE_EMAIL_FROM=QuickDraft <noreply@yourdomain.com>
